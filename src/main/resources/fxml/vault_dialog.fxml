<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<GridPane fx:controller="com.spacekeeperfx.ui.VaultDialogController"
          xmlns="http://javafx.com/javafx/21"
          xmlns:fx="http://javafx.com/fxml/1"
          hgap="10" vgap="10" styleClass="dialog" prefWidth="420">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Vault Name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="nameField" promptText="Enter a name"
               GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS"/>

    <HBox spacing="8" alignment="CENTER_RIGHT"
          GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="2">
        <Button text="Create" fx:id="okButton"    styleClass="primary" defaultButton="true"/>
        <Button text="Cancel" fx:id="cancelButton" styleClass="ghost" cancelButton="true"/>
    </HBox>
</GridPane>
